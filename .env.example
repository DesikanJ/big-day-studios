# Site URL (canonical URLs, sitemap, Open Graph)
PUBLIC_SITE_URL=https://bigdaystudios.in

# Optional local SEO (edit src/config/site.ts or set here later)
# PUBLIC_GOOGLE_MAPS_URL=https://maps.google.com/?cid=...
# PUBLIC_STREET_ADDRESS=Your studio street address, Chennai

# WhatsApp — country code + number, no + or spaces
PUBLIC_WHATSAPP_NUMBER=919840451199

# Contact form — https://web3forms.com (free)
PUBLIC_WEB3FORMS_ACCESS_KEY=your_access_key_here

# Cloudinary — https://cloudinary.com (free tier)
PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
# Optional: parent folder if paths are big-day/Wedding/... (omit if Wedding is at root)
# PUBLIC_CLOUDINARY_FOLDER=

# For npm run sync:galleries only (Dashboard → Settings → API Keys) — never commit real values
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
