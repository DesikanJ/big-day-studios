# Site URL (used for sitemap, OG tags)
PUBLIC_SITE_URL=https://bigdaystudios.com

# WhatsApp — country code + number, no + or spaces (e.g. 919876543210)
PUBLIC_WHATSAPP_NUMBER=919876543210

# Contact form — https://web3forms.com (free)
PUBLIC_WEB3FORMS_ACCESS_KEY=your_access_key_here

# Cloudinary — https://cloudinary.com (free tier)
PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
# Optional: folder prefix for uploads
PUBLIC_CLOUDINARY_FOLDER=big-day
