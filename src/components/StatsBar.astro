---
import { site } from '@/config/site';
---

<section class="stats" aria-label="Studio highlights">
  <div class="stats__inner">
    {
      site.stats.map((stat) => (
        <div class="stats__item">
          <p class="stats__value">{stat.value}</p>
          <p class="stats__label">{stat.label}</p>
        </div>
      ))
    }
  </div>
</section>

<style>
  .stats {
    position: relative;
    height: clamp(120px, calc(146 / 1440 * 100vw), 146px);
    border-top: 0.4px solid transparent;
    border-image: var(--gradient-border) 1;
    background: transparent;
  }

  .stats__inner {
    position: relative;
    width: min(var(--figma-max), 100%);
    height: 100%;
    margin: 0 auto;
  }

  .stats__item {
    position: absolute;
    top: calc(40 / 146 * 100%);
    width: calc(160 / 1440 * 100%);
    min-width: 120px;
    text-align: center;
  }

  .stats__item:nth-child(1) {
    left: calc(145 / 1440 * 100%);
  }

  .stats__item:nth-child(2) {
    left: calc(475 / 1440 * 100%);
  }

  .stats__item:nth-child(3) {
    left: calc(805 / 1440 * 100%);
  }

  .stats__item:nth-child(4) {
    left: calc(1135 / 1440 * 100%);
  }

  .stats__value {
    font-family: var(--font-serif);
    font-size: clamp(1.75rem, 2.64vw, 38px);
    font-weight: 400;
    line-height: 40px;
    text-transform: uppercase;
    margin: 0 0 14px;
  }

  .stats__label {
    font-family: var(--font-sans);
    font-size: 14px;
    line-height: 18px;
    letter-spacing: 0;
    text-transform: uppercase;
    color: var(--color-muted);
    margin: 0;
  }

  @media (max-width: 900px) {
    .stats {
      height: auto;
    }

    .stats__inner {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
      padding: 2rem var(--figma-gutter);
    }

    .stats__item {
      position: static;
      width: auto;
      min-width: 0;
    }
  }
</style>
