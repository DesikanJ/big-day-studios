---
import {
  imageUrl,
  placeholderUrl,
  responsiveWidths,
  srcSet,
  usesCloudinaryForSrc,
} from '@/lib/cloudinary';

interface Props {
  src: string;
  alt: string;
  width: number;
  height: number;
  sizes?: string;
  priority?: boolean;
  class?: string;
  fill?: boolean;
  /** Preserve original aspect ratio (masonry galleries). Default false = crop to frame. */
  natural?: boolean;
  /** LQIP blur while loading (Cloudinary only). Default true. */
  placeholder?: boolean;
}

const {
  src,
  alt,
  width,
  height,
  sizes = '100vw',
  priority = false,
  class: className,
  fill = false,
  natural = false,
  placeholder = true,
} = Astro.props;

const cloud = usesCloudinaryForSrc(src);
const widths = responsiveWidths(width);
const defaultW = widths[widths.length - 1] ?? Math.min(width, 1280);
const mainSrc = imageUrl(src, { width: defaultW, dpr: cloud ? 'auto' : undefined });
const set = srcSet(src, widths);
const lqip = placeholder && cloud ? placeholderUrl(src) : null;
---

{
  fill ? (
    <span
      class:list={['photo-wrap', 'photo-wrap--fill', className]}
      style={lqip ? `background-image:url(${lqip})` : undefined}
    >
      <img
        src={mainSrc}
        srcset={set || undefined}
        sizes={set ? sizes : undefined}
        alt={alt}
        width={width}
        height={height}
        loading={priority ? 'eager' : 'lazy'}
        decoding={priority ? 'sync' : 'async'}
        fetchpriority={priority ? 'high' : 'auto'}
        class:list={['photo-img', 'photo-img--fill', lqip && 'photo-img--fade']}
      />
    </span>
  ) : (
    <span
      class:list={['photo-frame', natural && 'photo-frame--natural', className]}
      style={`--photo-ar: ${width} / ${height};${lqip ? `background-image:url(${lqip})` : ''}`}
    >
      <img
        src={mainSrc}
        srcset={set || undefined}
        sizes={set ? sizes : undefined}
        alt={alt}
        width={width}
        height={height}
        loading={priority ? 'eager' : 'lazy'}
        decoding={priority ? 'sync' : 'async'}
        fetchpriority={priority ? 'high' : 'auto'}
        class:list={['photo-img', lqip && 'photo-img--fade']}
      />
    </span>
  )
}

<script>
  document.querySelectorAll('.photo-img--fade').forEach((img) => {
    const mark = () => img.classList.add('is-loaded');
    const fail = () => {
      img.classList.add('is-loaded');
      img.style.opacity = '1';
    };
    if (img.complete && img.naturalWidth > 0) mark();
    else {
      img.addEventListener('load', mark, { once: true });
      img.addEventListener('error', fail, { once: true });
    }
  });
</script>

<style>
  .photo-frame,
  .photo-wrap {
    display: block;
    background-color: var(--color-surface);
    background-size: cover;
    background-position: center;
  }

  .photo-frame {
    position: relative;
    width: 100%;
    aspect-ratio: var(--photo-ar);
    overflow: hidden;
  }

  .photo-wrap--fill {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .photo-img {
    display: block;
    max-width: 100%;
  }

  .photo-img--fade {
    opacity: 1;
    transition: opacity 0.35s ease;
  }

  .photo-img--fade:not(.is-loaded) {
    opacity: 0.85;
  }

  .photo-img--fade.is-loaded {
    opacity: 1;
  }

  .photo-frame--natural {
    aspect-ratio: auto;
    overflow: hidden;
    border-radius: var(--radius);
  }

  .photo-frame--natural .photo-img {
    position: static;
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  .photo-frame .photo-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    max-width: none;
    object-fit: cover;
    object-position: center;
  }

  .photo-img--fill {
    width: 100%;
    height: 100%;
    max-width: none;
    object-fit: cover;
    object-position: center;
  }

  @media (prefers-reduced-motion: reduce) {
    .photo-img--fade {
      transition: none;
      opacity: 1;
    }
  }
</style>
