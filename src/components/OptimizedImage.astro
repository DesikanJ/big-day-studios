---
import { imageUrl, srcSet } from '@/lib/cloudinary';

interface Props {
  src: string;
  alt: string;
  width: number;
  height: number;
  sizes?: string;
  priority?: boolean;
  class?: string;
  /** When true, fills parent (parent must have size). Default: preserve aspect ratio in a frame. */
  fill?: boolean;
}

const {
  src,
  alt,
  width,
  height,
  sizes = '100vw',
  priority = false,
  class: className,
  fill = false,
} = Astro.props;

const widths = [400, 640, 960, 1280, 1600].filter((w) => w <= width * 2 || w <= 1600);
const mainSrc = imageUrl(src, { width: Math.min(width, 1280), quality: 'auto', format: 'auto' });
const set = srcSet(src, widths.length ? widths : [640, 1280], { quality: 'auto', format: 'auto' });
---

{
  fill ? (
    <img
      src={mainSrc}
      srcset={set}
      sizes={sizes}
      alt={alt}
      width={width}
      height={height}
      loading={priority ? 'eager' : 'lazy'}
      decoding={priority ? 'sync' : 'async'}
      fetchpriority={priority ? 'high' : 'auto'}
      class:list={['photo-img', 'photo-img--fill', className]}
    />
  ) : (
    <span
      class:list={['photo-frame', className]}
      style={`--photo-ar: ${width} / ${height}`}
    >
      <img
        src={mainSrc}
        srcset={set}
        sizes={sizes}
        alt={alt}
        width={width}
        height={height}
        loading={priority ? 'eager' : 'lazy'}
        decoding={priority ? 'sync' : 'async'}
        fetchpriority={priority ? 'high' : 'auto'}
        class="photo-img"
      />
    </span>
  )
}

<style>
  .photo-frame {
    display: block;
    position: relative;
    width: 100%;
    aspect-ratio: var(--photo-ar);
    overflow: hidden;
    background: var(--color-surface);
  }

  .photo-img {
    display: block;
    max-width: 100%;
  }

  .photo-frame .photo-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    max-width: none;
    object-fit: cover;
    object-position: center;
  }

  .photo-img--fill {
    width: 100%;
    height: 100%;
    max-width: none;
    object-fit: cover;
    object-position: center;
  }
</style>
