---
import OptimizedImage from '@/components/OptimizedImage.astro';
import { categories } from '@/data/categories';
import { getCategoryCoverSrc, getGallery } from '@/data/galleries';

const sorted = [...categories].sort((a, b) => a.order - b.order);
---

<section class="categories" id="services">
  <div class="container categories__header">
    <p class="section-label">What we do</p>
    <h2 class="section-title">Our Photography Services</h2>
    <p class="section-lead">
      From the first heartbeat to the last dance — we capture every chapter of your story with warmth and artistry.
    </p>
  </div>
  <div class="container categories__grid">
    {
      sorted.map((cat) => {
        const cover = getCategoryCoverSrc(cat.slug);
        const first = getGallery(cat.slug)?.photos[0];
        return (
          <a href={`/gallery/${cat.slug}/`} class="category-card">
            <div class="category-card__media">
              <OptimizedImage
                src={cover}
                alt={cat.title}
                width={first?.width ?? 1160}
                height={first?.height ?? 773}
                sizes="(max-width: 640px) 100vw, 280px"
              />
            </div>
            <div class="category-card__body">
              <h3 class="category-card__title">{cat.title}</h3>
              <p class="category-card__tagline">{cat.tagline}</p>
            </div>
          </a>
        );
      })
    }
  </div>
</section>

<style>
  .categories {
    padding: 4rem 0;
  }

  .categories__header {
    margin-bottom: 3rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .categories__grid {
    display: grid;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .categories__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .category-card {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 0;
    align-items: stretch;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: border-color 0.2s;
  }

  .category-card:hover {
    border-color: var(--color-accent);
  }

  @media (max-width: 520px) {
    .category-card {
      grid-template-columns: 1fr;
    }
  }

  .category-card__media {
    min-width: 0;
    align-self: stretch;
  }

  .category-card__media :global(.photo-frame) {
    height: 100%;
    min-height: 200px;
    aspect-ratio: 3 / 2;
  }

  .category-card__body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .category-card__title {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 400;
    margin-bottom: 0.35rem;
  }

  .category-card__tagline {
    color: var(--color-muted);
    font-size: 0.9rem;
  }
</style>
