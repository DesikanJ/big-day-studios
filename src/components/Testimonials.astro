---
import OptimizedImage from '@/components/OptimizedImage.astro';
---

<section class="testimonials" id="testimonials">
  <div class="container">
    <p class="section-label">Kind words</p>
    <h2 class="section-title">Families who trusted us</h2>
    <article class="testimonial-card">
      <span class="testimonial-card__quote" aria-hidden="true">"</span>
      <blockquote class="testimonial-card__text">
        The maternity shoot was everything we dreamed of. The team made us so comfortable, and the photos are absolutely stunning. We'll treasure these forever.
      </blockquote>
      <div class="testimonial-card__author">
        <OptimizedImage
          src="testimonial-avatar.png"
          alt=""
          width={34}
          height={34}
          sizes="34px"
          class="testimonial-card__avatar"
        />
        <div>
          <p class="testimonial-card__name">Priya & Anand</p>
          <p class="testimonial-card__meta">Maternity Shoot · Adyar</p>
        </div>
      </div>
    </article>
  </div>
</section>

<style>
  .testimonials {
    padding: 4rem 0;
  }

  .testimonials .section-title {
    margin-bottom: 2rem;
  }

  .testimonial-card {
    position: relative;
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem;
    border: 1px solid var(--color-accent-light);
    border-radius: var(--radius);
    background: var(--color-bg);
  }

  .testimonial-card__quote {
    font-family: var(--font-serif);
    font-size: 4rem;
    line-height: 1;
    color: var(--color-accent);
    position: absolute;
    top: 0.5rem;
    left: 1.5rem;
  }

  .testimonial-card__text {
    color: var(--color-quote);
    font-size: 1.05rem;
    line-height: 1.7;
    margin: 2rem 0 1.5rem;
    font-style: normal;
  }

  .testimonial-card__author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .testimonial-card__avatar {
    width: 34px;
    height: 34px;
    border-radius: 10px;
    object-fit: cover;
  }

  .testimonial-card__name {
    font-size: 0.9rem;
    color: var(--color-placeholder);
  }

  .testimonial-card__meta {
    font-size: 0.8rem;
    color: var(--color-accent);
  }
</style>
