---
import { site } from '@/config/site';
---

<section class="seo-faq" aria-labelledby="seo-faq-heading">
  <div class="container seo-faq__inner">
    <p class="section-label">FAQ</p>
    <h2 id="seo-faq-heading" class="seo-faq__title">Common questions</h2>
    <div class="seo-faq__list">
      {
        site.seo.faqs.map((faq) => (
          <details class="seo-faq__item">
            <summary>{faq.q}</summary>
            <p>{faq.a}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>

<style>
  .seo-faq {
    padding: 3rem 0;
    border-top: 1px solid var(--color-border);
  }

  .seo-faq__title {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 400;
    margin: 0 0 1.5rem;
  }

  .seo-faq__list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    max-width: 40rem;
  }

  .seo-faq__item {
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 0 1rem;
    background: var(--color-surface);
  }

  .seo-faq__item summary {
    cursor: pointer;
    padding: 1rem 0;
    font-weight: 500;
    list-style: none;
  }

  .seo-faq__item summary::-webkit-details-marker {
    display: none;
  }

  .seo-faq__item p {
    margin: 0 0 1rem;
    color: var(--color-muted);
    line-height: 1.6;
    font-size: 0.9375rem;
  }
</style>
