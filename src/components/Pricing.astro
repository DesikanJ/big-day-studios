---
import { packages } from '@/data/packages';
import { whatsappUrl } from '@/config/site';

function bookMessage(pkgName: string): string {
  return `Hi Big Day Studios! I'm interested in the ${pkgName} package. Can we discuss availability?`;
}

const [essential, premium, grand] = packages;
---

<section class="pricing" id="pricing" aria-labelledby="pricing-heading">
  <div class="pricing__inner">
    <h2 id="pricing-heading" class="section-title pricing__title">Simple, Honest Packages</h2>
    <p class="section-lead pricing__lead">
      No hidden charges. Everything you see is everything you get — for real memories that last
      generations.
    </p>

    <div class="pricing__row">
      {
        essential && (
          <article class="pricing-card">
            <div class="pricing-card__inner">
              <div class="pricing-card__head">
                <div>
                  <h3 class="pricing-card__name">{essential.name}</h3>
                  <p class="pricing-card__tagline">{essential.tagline}</p>
                </div>
                <div class="pricing-card__price-wrap">
                  <p class="pricing-card__price">{essential.price}</p>
                  <p class="pricing-card__note">{essential.priceNote}</p>
                </div>
              </div>

              <div class="pricing-card__divider" aria-hidden="true">
                <span />
                <span class="pricing-card__divider-label">Includes</span>
                <span />
              </div>

              <ul class="pricing-card__features">
                {essential.features.map((feature) => (
                  <li>
                    <svg class="pricing-card__star" viewBox="0 0 14 14" aria-hidden="true">
                      <path
                        d="M7 0l1.76 3.57 3.94.57-2.85 2.78.67 3.92L7 8.87 3.48 10.84l.67-3.92L1.3 4.14l3.94-.57L7 0z"
                        fill="currentColor"
                      />
                    </svg>
                    {feature}
                  </li>
                ))}
              </ul>

              <a
                href={whatsappUrl(bookMessage(essential.name))}
                class="btn btn--primary pricing-card__cta"
                target="_blank"
                rel="noopener noreferrer"
              >
                Book this package
              </a>
            </div>
          </article>
        )
      }

      {
        premium && (
          <article class="pricing-card pricing-card--featured">
            <div class="pricing-card__inner">
              <div class="pricing-card__head">
                <div>
                  <h3 class="pricing-card__name">{premium.name}</h3>
                  <p class="pricing-card__tagline">{premium.tagline}</p>
                </div>
                <div class="pricing-card__price-wrap">
                  <p class="pricing-card__price">{premium.price}</p>
                  <p class="pricing-card__note">{premium.priceNote}</p>
                </div>
              </div>

              <div class="pricing-card__divider" aria-hidden="true">
                <span />
                <span class="pricing-card__divider-label">Includes</span>
                <span />
              </div>

              <ul class="pricing-card__features pricing-card__features--cols">
                {premium.features.map((feature) => (
                  <li>
                    <svg class="pricing-card__star" viewBox="0 0 14 14" aria-hidden="true">
                      <path
                        d="M7 0l1.76 3.57 3.94.57-2.85 2.78.67 3.92L7 8.87 3.48 10.84l.67-3.92L1.3 4.14l3.94-.57L7 0z"
                        fill="currentColor"
                      />
                    </svg>
                    {feature}
                  </li>
                ))}
              </ul>

              <a
                href={whatsappUrl(bookMessage(premium.name))}
                class="btn btn--primary pricing-card__cta"
                target="_blank"
                rel="noopener noreferrer"
              >
                Book this package
              </a>
            </div>
          </article>
        )
      }
    </div>

    {
      grand && (
        <article class="pricing-card pricing-card--grand">
          <div class="pricing-card__inner">
            <div class="pricing-card__head pricing-card__head--grand">
              <div>
                <h3 class="pricing-card__name">{grand.name}</h3>
                <p class="pricing-card__tagline">{grand.tagline}</p>
              </div>
              <div class="pricing-card__price-wrap">
                <p class="pricing-card__price">{grand.price}</p>
                <p class="pricing-card__note">{grand.priceNote}</p>
              </div>
            </div>

            <div class="pricing-card__divider pricing-card__divider--grand" aria-hidden="true">
              <span />
              <span class="pricing-card__divider-label">Includes</span>
              <span />
            </div>

            <ul class="pricing-card__features pricing-card__features--grand">
              {grand.features.map((feature) => (
                <li>
                  <svg class="pricing-card__star" viewBox="0 0 14 14" aria-hidden="true">
                    <path
                      d="M7 0l1.76 3.57 3.94.57-2.85 2.78.67 3.92L7 8.87 3.48 10.84l.67-3.92L1.3 4.14l3.94-.57L7 0z"
                      fill="currentColor"
                    />
                  </svg>
                  {feature}
                </li>
              ))}
            </ul>

            <a
              href={whatsappUrl(bookMessage(grand.name))}
              class="btn btn--outline pricing-card__cta pricing-card__cta--grand"
              target="_blank"
              rel="noopener noreferrer"
            >
              Book this package
            </a>
          </div>
        </article>
      )
    }
  </div>
</section>

<style>
  .pricing {
    padding: 203px var(--figma-gutter) 120px;
    background: var(--color-bg);
  }

  .pricing__inner {
    max-width: var(--figma-max);
    margin: 0 auto;
  }

  .pricing__title {
    max-width: 599px;
    margin: 0 auto 40px;
  }

  .pricing__lead {
    margin-bottom: 118px;
  }

  .pricing__row {
    display: grid;
    gap: 40px;
    margin-bottom: 40px;
  }

  @media (min-width: 1100px) {
    .pricing__row {
      grid-template-columns: repeat(2, minmax(0, 576px));
      justify-content: center;
    }
  }

  .pricing-card {
    position: relative;
    border-radius: 4px;
    padding: 1px;
    background: var(--gradient-border);
  }

  .pricing-card__inner {
    min-height: 452px;
    display: flex;
    flex-direction: column;
    padding: 38px 40px 40px;
    border-radius: 3px;
    background: var(--gradient-card-dark);
  }

  .pricing-card--featured {
    background: linear-gradient(
      71deg,
      rgb(30 16 0) 0%,
      rgb(156 92 0) 65%,
      rgb(239 191 121) 100%
    );
  }

  .pricing-card--featured::before {
    content: '';
    position: absolute;
    top: -1rem;
    right: 2.5rem;
    width: 8rem;
    height: 2rem;
    border-radius: 999px;
    background: var(--color-price);
    filter: blur(24px);
    opacity: 0.55;
    pointer-events: none;
  }

  .pricing-card--featured .pricing-card__inner {
    background: var(--gradient-card-featured);
  }

  .pricing-card--grand {
    max-width: 1192px;
    margin: 0 auto;
    background: linear-gradient(
      -45deg,
      #b57518 0%,
      #1e1302 43%,
      #b48643 99%
    );
  }

  .pricing-card--grand .pricing-card__inner {
    min-height: 342px;
    background: var(--gradient-card);
  }

  .pricing-card__head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 48px;
  }

  .pricing-card__head--grand {
    margin-bottom: 32px;
  }

  .pricing-card__name {
    font-family: var(--font-serif);
    font-size: 32px;
    font-weight: 400;
    line-height: 42px;
    margin-bottom: 4px;
  }

  .pricing-card__tagline {
    color: var(--color-muted);
    font-size: 10px;
    line-height: 18px;
  }

  .pricing-card__price-wrap {
    text-align: right;
    flex-shrink: 0;
  }

  .pricing-card__price {
    font-family: var(--font-serif);
    font-size: 40px;
    line-height: 52px;
    color: var(--color-price);
  }

  .pricing-card__note {
    color: var(--color-price-note);
    font-size: 10px;
    line-height: 18px;
  }

  .pricing-card__divider {
    display: grid;
    grid-template-columns: 193px auto 1fr;
    align-items: center;
    gap: 20px;
    margin-bottom: 32px;
  }

  .pricing-card__divider--grand {
    grid-template-columns: 3px auto 1fr;
    max-width: 680px;
    margin-inline: auto;
    width: 100%;
  }

  .pricing-card__divider span:first-child {
    height: 1px;
    background: linear-gradient(90deg, rgb(3 3 3) 0%, rgb(239 191 121) 100%);
  }

  .pricing-card__divider span:last-child {
    height: 1px;
    background: linear-gradient(90deg, rgb(239 191 121) 0%, rgb(3 3 3) 100%);
  }

  .pricing-card__divider-label {
    font-size: 14px;
    line-height: 18px;
    text-transform: uppercase;
    color: var(--color-accent-light);
    white-space: nowrap;
  }

  .pricing-card__features {
    list-style: none;
    padding: 0;
    margin: 0 0 auto;
    display: flex;
    flex-direction: column;
    gap: 14px;
    flex: 1;
  }

  .pricing-card__features--cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: 28px;
    row-gap: 14px;
  }

  .pricing-card__features--grand {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    column-gap: 48px;
    row-gap: 14px;
    max-width: 900px;
    margin-inline: auto;
    width: 100%;
  }

  .pricing-card__features li {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    color: var(--color-muted);
    font-size: 16px;
    line-height: 18px;
  }

  .pricing-card__star {
    flex-shrink: 0;
    width: 14px;
    height: 14px;
    margin-top: 2px;
    color: var(--color-accent-light);
  }

  .pricing-card__cta {
    width: 100%;
    max-width: 496px;
    margin-top: 32px;
    align-self: center;
  }

  .pricing-card__cta--grand {
    max-width: 300px;
    margin-top: 24px;
  }

  @media (max-width: 768px) {
    .pricing {
      padding: 4rem var(--figma-gutter) 3rem;
    }

    .pricing__lead {
      margin-bottom: 3rem;
    }

    .pricing-card__head {
      flex-direction: column;
    }

    .pricing-card__price-wrap {
      text-align: left;
    }

    .pricing-card__features--cols,
    .pricing-card__features--grand {
      grid-template-columns: 1fr;
    }

    .pricing-card__divider {
      grid-template-columns: 1fr auto 1fr;
    }
  }
</style>
