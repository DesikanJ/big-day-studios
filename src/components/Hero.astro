---
import OptimizedImage from '@/components/OptimizedImage.astro';
import { whatsappUrl } from '@/config/site';

/** Figma Desktop-1 — Group 9 @ (94,143) 1274×675, fold ends @ y:877 */
const heroLead =
  'Premium wedding, maternity & newborn photography that captures the warmth, tradition, and joy of your most cherished milestones.';

const COLLAGE = { w: 1274, h: 675, left: 94, top: 143 } as const;

const collagePhotos = [
  { src: 'hero-4.png', alt: '', width: 480, height: 320, left: 0, top: 37, w: 179, h: 230 },
  { src: 'hero-1.png', alt: '', width: 320, height: 479, left: 759, top: 0, w: 151, h: 194 },
  { src: 'hero-2.png', alt: '', width: 320, height: 480, left: 1095, top: 79, w: 179, h: 230 },
  { src: 'hero-3.png', alt: '', width: 480, height: 320, left: 972, top: 445, w: 179, h: 230 },
  { src: 'hero-5.png', alt: '', width: 320, height: 479, left: 89, top: 449, w: 162, h: 210 },
] as const;
---

<section class="hero" aria-label="Introduction">
  <div class="hero__stage">
    <div class="hero__collage" aria-hidden="true">
      {
        collagePhotos.map((img, i) => (
          <div
            class="hero__tile"
            style={`
              left: ${(img.left / COLLAGE.w) * 100}%;
              top: ${(img.top / COLLAGE.h) * 100}%;
              width: ${(img.w / COLLAGE.w) * 100}%;
              height: ${(img.h / COLLAGE.h) * 100}%;
            `}
          >
            <OptimizedImage
              src={img.src}
              alt={img.alt}
              width={img.width}
              height={img.height}
              priority={i === 0}
              fill
              sizes="180px"
            />
          </div>
        ))
      }
    </div>

    <h1 class="hero__title">
      Every moment,<br />beautifully yours.
    </h1>
    <p class="hero__lead">{heroLead}</p>
    <div class="hero__actions">
      <a href={whatsappUrl()} class="btn btn--primary" target="_blank" rel="noopener noreferrer">
        Book via Whatsapp
      </a>
      <a href="/gallery/" class="btn btn--outline">View gallery</a>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 0;
    background: transparent;
  }

  .hero__stage {
    position: relative;
    width: min(100%, var(--figma-max));
    margin: 0 auto;
    height: clamp(520px, calc(877 / 1440 * 100vw), 877px);
  }

  .hero__collage {
    position: absolute;
    left: calc(94 / 1440 * 100%);
    top: calc(143 / 877 * 100%);
    width: calc(1274 / 1440 * 100%);
    height: calc(675 / 877 * 100%);
    pointer-events: none;
    z-index: 1;
  }

  .hero__tile {
    position: absolute;
    overflow: hidden;
    border-radius: var(--radius);
  }

  .hero__title {
    position: absolute;
    z-index: 2;
    left: calc(265 / 1440 * 100%);
    top: calc(240 / 877 * 100%);
    width: calc(911 / 1440 * 100%);
    margin: 0;
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(2.75rem, 8.333vw, 120px);
    line-height: 1.04;
    letter-spacing: 0;
    text-transform: uppercase;
    text-align: center;
    color: var(--color-text);
    pointer-events: none;
  }

  .hero__lead {
    position: absolute;
    z-index: 2;
    left: calc(440 / 1440 * 100%);
    top: calc(552 / 877 * 100%);
    width: calc(561 / 1440 * 100%);
    margin: 0;
    color: var(--color-muted);
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.25;
    text-align: center;
    pointer-events: none;
  }

  .hero__actions {
    position: absolute;
    z-index: 2;
    left: calc(498 / 1440 * 100%);
    top: calc(682 / 877 * 100%);
    width: calc(444 / 1440 * 100%);
    height: calc(52 / 877 * 100%);
    min-height: 52px;
    pointer-events: auto;
  }

  .hero__actions :global(.btn) {
    position: absolute;
    top: 0;
    flex: none;
    padding: 16px 30px;
  }

  .hero__actions :global(.btn--primary) {
    left: 0;
  }

  .hero__actions :global(.btn--outline) {
    left: calc(264 / 444 * 100%);
  }

  @media (max-width: 900px) {
    .hero__stage {
      height: auto;
      min-height: 640px;
      padding: 5rem 1.25rem 2rem;
    }

    .hero__collage {
      left: 1.25rem;
      right: 1.25rem;
      width: auto;
      top: 5rem;
      height: 40%;
      opacity: 0.85;
    }

    .hero__title,
    .hero__lead,
    .hero__actions {
      position: relative;
      left: auto;
      top: auto;
      width: 100%;
      max-width: none;
    }

    .hero__title {
      margin-top: 46%;
      padding-top: 1rem;
      font-size: clamp(2.5rem, 10vw, 4rem);
    }

    .hero__lead {
      margin-top: 1rem;
    }

    .hero__actions {
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 10px;
      width: min(100%, 20rem);
      height: auto;
      margin: 1.5rem auto 0;
    }

    .hero__actions :global(.btn) {
      position: static;
      width: 100%;
    }

    .hero__tile:nth-child(3) {
      display: none;
    }
  }

  @media (max-width: 520px) {
    .hero__tile:nth-child(2),
    .hero__tile:nth-child(4) {
      display: none;
    }
  }
</style>
