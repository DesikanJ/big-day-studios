---
import BaseLayout from '@/layouts/BaseLayout.astro';
import GalleryGrid from '@/components/GalleryGrid.astro';
import SeoBreadcrumbs from '@/components/SeoBreadcrumbs.astro';
import { categories, getCategory } from '@/data/categories';
import { getGallery } from '@/data/galleries';
import { categoryCoverForOg } from '@/lib/category-cover';
import { whatsappUrl } from '@/config/site';
import { breadcrumbJsonLd, servicePageJsonLd, truncateDescription } from '@/lib/seo';

export function getStaticPaths() {
  return categories.map((cat) => ({ params: { slug: cat.slug } }));
}

const { slug } = Astro.params;
const category = getCategory(slug!);
const gallery = getGallery(slug!);
const photos = gallery?.photos ?? [];
const siteOrigin = Astro.site?.toString() ?? 'https://bigdaystudios.in';

if (!category) {
  return Astro.redirect('/gallery/');
}
---

<BaseLayout
  title={category.seoTitle}
  description={truncateDescription(category.seoDescription)}
  ogImage={categoryCoverForOg(category.slug, siteOrigin)}
  jsonLd={[
    breadcrumbJsonLd([
      { name: 'Home', path: '/' },
      { name: 'Gallery', path: '/gallery/' },
      { name: category.title, path: `/gallery/${category.slug}/` },
    ]),
    servicePageJsonLd(category),
  ]}
>
  <section class="page-hero container">
    <SeoBreadcrumbs
      items={[
        { label: 'Home', href: '/' },
        { label: 'Gallery', href: '/gallery/' },
        { label: category.title },
      ]}
    />
    <p class="section-label">{category.tagline}</p>
    <h1 class="section-title">{category.title}</h1>
    <p class="section-lead">{category.description}</p>
    <div class="btn-group" style="margin-top: 1.5rem">
      <a
        href={whatsappUrl(`Hi! I'd like to book a ${category.title} session.`)}
        class="btn btn--primary"
        target="_blank"
        rel="noopener noreferrer"
      >
        Book this session
      </a>
    </div>
  </section>
  <section class="container gallery-page">
    {
      photos.length > 0 ? (
        <GalleryGrid photos={photos} />
      ) : (
        <p class="gallery-empty">
          Photos for this collection are being prepared. Please check back soon or message us on WhatsApp.
        </p>
      )
    }
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding: 3rem 0 2rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .gallery-page {
    padding-bottom: 4rem;
  }

  .gallery-empty {
    text-align: center;
    color: var(--color-muted);
    padding: 3rem 1rem;
    border: 1px dashed var(--color-border);
    border-radius: var(--radius);
  }
</style>
